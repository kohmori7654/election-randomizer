{
  "allowUnsandboxedCommands": false,
  "bypassPermissionsMode": "disable",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "/compact の実行前に SESSION.md を更新してください。現在進行中のタスク・中断箇所・次のステップ・このセッションで決定した事項を `.claude/workflows/session_handoff.md` の記載規約に従って書き出してください。SESSION.md が存在しない場合は新規作成してください。"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(ps *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(ss *)",
      "Bash(netstat *)",
      "Bash(which *)",
      "Bash(git status)",
      "Bash(git diff *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(cat .env*)",
      "Bash(cat *id_rsa*)",
      "Bash(cat *id_ed25519*)",
      "Bash(cat ~/.aws/credentials)",
      "Bash(head .env*)",
      "Bash(head *id_rsa*)",
      "Bash(head *id_ed25519*)",
      "Bash(head ~/.aws/credentials)",
      "Bash(tail .env*)",
      "Bash(tail *id_rsa*)",
      "Bash(tail *id_ed25519*)",
      "Bash(tail ~/.aws/credentials)",
      "Read(.env*)",
      "Read(*id_rsa*)",
      "Read(*id_ed25519*)",
      "Read(~/.aws/credentials)"
    ]
  }
}
